---
import '../styles/global.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import ThemeDecorations from '../components/ThemeDecorations.astro';

interface Props {
  title: string;
  description?: string;
  ogImage?: string;
}

const {
  title,
  description = "El Rey de los Pescados y Mariscos - MГЎs de 30 aГұos de tradiciГіn en el Muelle Pesquero El Mosquero, Puesto 3 y 4, MaiquetГӯa",
  ogImage = "/jose-lg.webp"
} = Astro.props;
const siteUrl = 'https://www.rpym.net';
const currentUrl = new URL(Astro.url.pathname, siteUrl).href;
const ogImageUrl = new URL(ogImage, siteUrl).href;
---

<!doctype html>
<html lang="es" data-theme="ocean">
  <head>
    <meta charset="UTF-8" />

    <!-- Theme initialization (prevent FOUC) -->
    <script is:inline>
      (function() {
        try {
          var VALID_THEMES = ['ocean','carnival','christmas','easter','valentine','mundial','halloween','campeones','ramos','cuaresma','jueves-santo','viernes-santo','sabado-santo','resurreccion'];
          var cached = localStorage.getItem('rpym_theme');
          if (cached && VALID_THEMES.includes(cached)) {
            document.documentElement.setAttribute('data-theme', cached);
          }

          // ===== MUNDIAL: 48 selecciones, paleta aleatoria por sesiГіn =====
          if (cached === 'mundial') {
            // Utilidades de color HSL вҶ” hex
            function h2hsl(hex) {
              var r=parseInt(hex.slice(1,3),16)/255,g=parseInt(hex.slice(3,5),16)/255,b=parseInt(hex.slice(5,7),16)/255;
              var mx=Math.max(r,g,b),mn=Math.min(r,g,b),h,s,l=(mx+mn)/2;
              if(mx===mn){h=s=0;}else{var d=mx-mn;s=l>.5?d/(2-mx-mn):d/(mx+mn);switch(mx){case r:h=(g-b)/d+(g<b?6:0);break;case g:h=(b-r)/d+2;break;default:h=(r-g)/d+4;}h/=6;}
              return [h*360,s*100,l*100];
            }
            function hsl2h(h,s,l) {
              s/=100;l/=100;var a=s*Math.min(l,1-l);
              var f=function(n){var k=(n+h/30)%12;return Math.round((l-a*Math.max(Math.min(k-3,9-k,1),-1))*255);};
              return '#'+[f(0),f(8),f(4)].map(function(v){return v.toString(16).padStart(2,'0');}).join('');
            }
            function genP(hex) {
              var c=h2hsl(hex),h=c[0],s=c[1],l=c[2];
              var ls=[97,93,87,78,70,l,Math.max(l-10,10),Math.max(l-22,7),Math.max(l-33,4),Math.max(l-42,2),Math.max(l-48,1)];
              var ss=[s*.1+5,s*.2+8,s*.45+5,s*.75,s*.9,s,s*.92,s*.85,s*.78,s*.72,s*.65];
              return ls.map(function(li,i){return hsl2h(h,Math.min(100,ss[i]),li);});
            }
            function genA(hex) {
              var c=h2hsl(hex),h=c[0],s=c[1],l=c[2];
              var ls=[95,80,l,Math.max(l-10,8),Math.max(l-22,5)];
              var ss=[s*.15+5,s*.7,s,s*.9,s*.8];
              return ls.map(function(li,i){return hsl2h(h,Math.min(100,ss[i]),li);});
            }

            // [id, nombre, bandera, colorPrimario, colorAcento, textoSobrePrimario, bgDesde, bgHasta]
            var T=[
              // CONMEBOL
              ['argentina','Argentina','рҹҮҰрҹҮ·','#3788C8','#F6B40E','#fff','#EBF5FB','#FEF9E7'],
              ['brazil','Brasil','рҹҮ§рҹҮ·','#009C3B','#E8C400','#fff','#E8F5E9','#FFFDE7'],
              ['uruguay','Uruguay','рҹҮәрҹҮҫ','#4DA8D8','#001A72','#fff','#E3F2FD','#EFF6FF'],
              ['colombia','Colombia','рҹҮЁрҹҮҙ','#C8910A','#003087','#fff','#FFF8E1','#E8EAF6'],
              ['ecuador','Ecuador','рҹҮӘрҹҮЁ','#C59A00','#003DA5','#fff','#FFF8E1','#E3F2FD'],
              ['venezuela','Venezuela','рҹҮ»рҹҮӘ','#8B1A2D','#CBA135','#fff','#FCE4EC','#FFF8E1'],
              ['chile','Chile','рҹҮЁрҹҮұ','#D52B1E','#002868','#fff','#FFEBEE','#E3F2FD'],
              ['paraguay','Paraguay','рҹҮөрҹҮҫ','#CE2028','#003893','#fff','#FFEBEE','#E8EAF6'],
              // UEFA
              ['france','Francia','рҹҮ«рҹҮ·','#002395','#ED2939','#fff','#E8EAF6','#FFEBEE'],
              ['germany','Alemania','рҹҮ©рҹҮӘ','#3D3D3D','#CC0000','#fff','#F5F5F5','#FFEBEE'],
              ['spain','EspaГұa','рҹҮӘрҹҮё','#C60B1E','#FFC400','#fff','#FFEBEE','#FFFDE7'],
              ['england','Inglaterra','рҹҮ¬рҹҮ§','#1B3A6B','#CF142B','#fff','#E3F2FD','#FFEBEE'],
              ['portugal','Portugal','рҹҮөрҹҮ№','#BA0021','#006600','#fff','#FFEBEE','#E8F5E9'],
              ['netherlands','PaГӯses Bajos','рҹҮірҹҮұ','#D4500A','#003DA5','#fff','#FFF3E0','#E3F2FD'],
              ['belgium','BГ©lgica','рҹҮ§рҹҮӘ','#EF3340','#F0A500','#fff','#FFEBEE','#FFF8E1'],
              ['italy','Italia','рҹҮ®рҹҮ№','#0066CC','#E8B020','#fff','#E3F2FD','#FFFDE7'],
              ['croatia','Croacia','рҹҮӯрҹҮ·','#CC0000','#172983','#fff','#FFEBEE','#E8EAF6'],
              ['switzerland','Suiza','рҹҮЁрҹҮӯ','#CF0A2C','#3D3D3D','#fff','#FFEBEE','#F5F5F5'],
              ['poland','Polonia','рҹҮөрҹҮұ','#DC143C','#002868','#fff','#FFEBEE','#E3F2FD'],
              ['denmark','Dinamarca','рҹҮ©рҹҮ°','#C60C30','#00A3DA','#fff','#FFEBEE','#E3F2FD'],
              ['austria','Austria','рҹҮҰрҹҮ№','#ED2939','#C4A020','#fff','#FFEBEE','#FFFDE7'],
              ['serbia','Serbia','рҹҮ·рҹҮё','#C6363C','#0C4076','#fff','#FFEBEE','#E3F2FD'],
              ['scotland','Escocia','рҹҸҙу Ғ§у Ғўу Ғіу ҒЈу Ғҙу Ғҝ','#003380','#C8A800','#fff','#E3F2FD','#FFFDE7'],
              ['turkey','TurquГӯa','рҹҮ№рҹҮ·','#E30A17','#002868','#fff','#FFEBEE','#E3F2FD'],
              // CONCACAF
              ['usa','EE. UU.','рҹҮәрҹҮё','#002868','#BF0A30','#fff','#E3F2FD','#FFEBEE'],
              ['mexico','MГ©xico','рҹҮІрҹҮҪ','#006847','#CE1126','#fff','#E8F5E9','#FFEBEE'],
              ['canada','CanadГЎ','рҹҮЁрҹҮҰ','#CC0000','#222222','#fff','#FFEBEE','#F5F5F5'],
              ['costa_rica','Costa Rica','рҹҮЁрҹҮ·','#002BB4','#CE1126','#fff','#E3F2FD','#FFEBEE'],
              ['honduras','Honduras','рҹҮӯрҹҮі','#003DA5','#C4A020','#fff','#E3F2FD','#FFFDE7'],
              ['jamaica','Jamaica','рҹҮҜрҹҮІ','#C49A00','#009B3A','#fff','#FFF8E1','#E8F5E9'],
              // CAF
              ['morocco','Marruecos','рҹҮІрҹҮҰ','#C1272D','#006233','#fff','#FFEBEE','#E8F5E9'],
              ['senegal','Senegal','рҹҮёрҹҮі','#00853F','#DF0D15','#fff','#E8F5E9','#FFEBEE'],
              ['nigeria','Nigeria','рҹҮірҹҮ¬','#008751','#C49A00','#fff','#E8F5E9','#FFF8E1'],
              ['ghana','Ghana','рҹҮ¬рҹҮӯ','#006B3F','#E8B800','#fff','#E8F5E9','#FFFDE7'],
              ['cameroon','CamerГәn','рҹҮЁрҹҮІ','#007A5E','#CE1126','#fff','#E8F5E9','#FFEBEE'],
              ['ivory_coast','Costa de Marfil','рҹҮЁрҹҮ®','#D4671E','#009A17','#fff','#FFF3E0','#E8F5E9'],
              ['algeria','Argelia','рҹҮ©рҹҮҝ','#006233','#D21034','#fff','#E8F5E9','#FFEBEE'],
              ['egypt','Egipto','рҹҮӘрҹҮ¬','#CE1126','#C4A020','#fff','#FFEBEE','#FFFDE7'],
              ['south_africa','SudГЎfrica','рҹҮҝрҹҮҰ','#007A4D','#D4A000','#fff','#E8F5E9','#FFF8E1'],
              // AFC
              ['japan','JapГіn','рҹҮҜрҹҮө','#1A237E','#BC002D','#fff','#E8EAF6','#FFEBEE'],
              ['south_korea','Corea del Sur','рҹҮ°рҹҮ·','#CD2E3A','#003478','#fff','#FFEBEE','#E3F2FD'],
              ['saudi_arabia','Arabia Saudita','рҹҮёрҹҮҰ','#006C35','#D4A800','#fff','#E8F5E9','#FFFDE7'],
              ['iran','IrГЎn','рҹҮ®рҹҮ·','#239F40','#DA0000','#fff','#E8F5E9','#FFEBEE'],
              ['australia','Australia','рҹҮҰрҹҮә','#C49A00','#00843D','#fff','#FFF8E1','#E8F5E9'],
              ['qatar','Catar','рҹҮ¶рҹҮҰ','#8D1B3D','#C4A020','#fff','#FCE4EC','#FFFDE7'],
              ['china','China','рҹҮЁрҹҮі','#DE2910','#D4A800','#fff','#FFEBEE','#FFFDE7'],
              ['indonesia','Indonesia','рҹҮ®рҹҮ©','#CE1126','#003DA5','#fff','#FFEBEE','#E3F2FD'],
              // OFC
              ['new_zealand','Nueva Zelanda','рҹҮірҹҮҝ','#00247D','#CC0000','#fff','#E3F2FD','#FFEBEE']
            ];

            // Seleccionar equipo (mismo durante la sesiГіn)
            var tid = sessionStorage.getItem('rpym_mundial_team');
            var team = null;
            if (tid) { for(var i=0;i<T.length;i++){if(T[i][0]===tid){team=T[i];break;}} }
            if (!team) {
              team = T[Math.floor(Math.random() * T.length)];
              sessionStorage.setItem('rpym_mundial_team', team[0]);
            }

            // Generar y aplicar paleta
            var ps = genP(team[3]), as = genA(team[4]);
            var root = document.documentElement;
            var pk=['--theme-primary-50','--theme-primary-100','--theme-primary-200','--theme-primary-300','--theme-primary-400','--theme-primary-500','--theme-primary-600','--theme-primary-700','--theme-primary-800','--theme-primary-900','--theme-primary-950'];
            var ak=['--theme-accent-100','--theme-accent-300','--theme-accent-400','--theme-accent-500','--theme-accent-600'];
            for(var pi=0;pi<pk.length;pi++) root.style.setProperty(pk[pi], ps[pi]);
            for(var ai=0;ai<ak.length;ai++) root.style.setProperty(ak[ai], as[ai]);
            root.style.setProperty('--theme-primary-fg', team[5]);
            root.style.setProperty('--theme-bg-from', team[6]);
            root.style.setProperty('--theme-bg-to', team[7]);
            root.setAttribute('data-mundial-team', team[1]);
            root.setAttribute('data-mundial-flag', team[2]);
          }
        } catch (e) {}
      })();
    </script>
    <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover" />
    <meta name="description" content={description} />
    <meta name="theme-color" content="#0c4a6e" />
    <meta name="robots" content="index, follow" />

    <!-- Canonical -->
    <link rel="canonical" href={currentUrl} />

    <!-- Open Graph -->
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:locale" content="es_VE" />
    <meta property="og:url" content={currentUrl} />
    <meta property="og:site_name" content="RPYM - El Rey de los Pescados y Mariscos" />
    <meta property="og:image" content={ogImageUrl} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content="RPYM - El Rey de los Pescados y Mariscos" />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageUrl} />

    <!-- DNS Prefetch para recursos externos -->
    <link rel="dns-prefetch" href="https://fonts.googleapis.com" />
    <link rel="dns-prefetch" href="https://fonts.gstatic.com" />

    <!-- Preconnect para Google Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />

    <!-- Preload imagen principal del hero -->
    <link rel="preload" as="image" href="/jose-lg.webp" type="image/webp" media="(min-width: 769px)" />
    <link rel="preload" as="image" href="/jose-md.webp" type="image/webp" media="(max-width: 768px)" />

    <!-- Google Fonts con display swap -->
    <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@400;600;700&family=Inter:wght@300;400;500;600&display=swap" rel="stylesheet" />

    <!-- Favicons -->
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" type="image/x-icon" href="/favicon.ico" />
    <link rel="icon" type="image/png" sizes="32x32" href="/icons/favicon-32x32.png" />
    <link rel="icon" type="image/png" sizes="16x16" href="/icons/favicon-16x16.png" />

    <!-- PWA Manifest -->
    <link rel="manifest" href="/manifest.json" />

    <!-- Apple PWA Meta Tags -->
    <meta name="apple-mobile-web-app-capable" content="yes" />
    <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent" />
    <meta name="apple-mobile-web-app-title" content="RPYM Admin" />
    <link rel="apple-touch-icon" href="/icons/apple-touch-icon.png" />
    <link rel="apple-touch-icon" sizes="152x152" href="/icons/icon-152x152.png" />
    <link rel="apple-touch-icon" sizes="180x180" href="/icons/apple-touch-icon.png" />
    <link rel="apple-touch-icon" sizes="167x167" href="/icons/icon-152x152.png" />

    <!-- Windows PWA -->
    <meta name="msapplication-TileColor" content="#0c4a6e" />
    <meta name="msapplication-TileImage" content="/icons/icon-144x144.png" />

    <!-- Mobile App Meta -->
    <meta name="mobile-web-app-capable" content="yes" />
    <meta name="application-name" content="RPYM Admin" />
    <meta name="format-detection" content="telephone=no" />

    <title>{title}</title>

    <!-- Schema.org Structured Data -->
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "LocalBusiness",
      "name": "RPYM - El Rey de los Pescados y Mariscos",
      "description": description,
      "url": siteUrl,
      "telephone": "+58-414-2145202",
      "address": {
        "@type": "PostalAddress",
        "streetAddress": "Muelle Pesquero El Mosquero, Puesto 3 y 4",
        "addressLocality": "MaiquetГӯa",
        "addressRegion": "La Guaira",
        "addressCountry": "VE"
      },
      "geo": {
        "@type": "GeoCoordinates",
        "latitude": "10.5936",
        "longitude": "-66.9546"
      },
      "openingHoursSpecification": [
        {
          "@type": "OpeningHoursSpecification",
          "dayOfWeek": ["Tuesday", "Wednesday", "Thursday", "Friday", "Saturday", "Sunday"],
          "opens": "06:00",
          "closes": "14:30"
        }
      ],
      "priceRange": "$$",
      "servesCuisine": "Mariscos",
      "image": siteUrl + "/jose-lg.webp"
    })} />
  </head>
  <body class="water-pattern min-h-screen flex flex-col">
    <ThemeDecorations />
    <Header />
    <main class="flex-1">
      <slot />
    </main>
    <Footer />

    <!-- Theme polling for real-time updates -->
    <script is:inline>
      (function() {
        var POLL_INTERVAL = 30000; // 30 seconds
        var VALID_THEMES = ['ocean', 'carnival', 'christmas', 'easter', 'valentine', 'mundial', 'halloween', 'campeones', 'ramos', 'cuaresma', 'jueves-santo', 'viernes-santo', 'sabado-santo', 'resurreccion'];

        function applyTheme(theme) {
          if (!VALID_THEMES.includes(theme)) return;
          localStorage.setItem('rpym_theme', theme);
          document.documentElement.setAttribute('data-theme', theme);
          // Update meta theme-color for mobile browsers
          var themeColors = {
            ocean: '#0c4a6e',
            carnival: '#7e22ce',
            christmas: '#b91c1c',
            easter: '#be185d',
            valentine: '#e11d48',
            mundial: '#16a34a',
            halloween: '#f97316',
            campeones: '#003DA5',
            ramos: '#4d7c0f',
            cuaresma: '#6b21a8',
            'jueves-santo': '#b45309',
            'viernes-santo': '#374151',
            'sabado-santo': '#4b5563',
            resurreccion: '#a16207'
          };
          var metaTheme = document.querySelector('meta[name="theme-color"]');
          if (metaTheme) metaTheme.setAttribute('content', themeColors[theme]);
        }

        async function checkTheme() {
          try {
            var response = await fetch('/api/config/theme', { cache: 'no-store' });
            if (response.ok) {
              var data = await response.json();
              var currentTheme = localStorage.getItem('rpym_theme') || 'ocean';
              if (data.theme && data.theme !== currentTheme) {
                applyTheme(data.theme);
              }
            }
          } catch (e) {
            console.error('Error checking theme:', e);
          }
        }

        // Initial check after page load
        if (document.readyState === 'complete') {
          checkTheme();
        } else {
          window.addEventListener('load', checkTheme);
        }

        // Poll every 30 seconds
        setInterval(checkTheme, POLL_INTERVAL);

        // Also check when tab becomes visible
        document.addEventListener('visibilitychange', function() {
          if (document.visibilityState === 'visible') {
            checkTheme();
          }
        });
      })();
    </script>

    <!-- Service Worker Registration -->
    <script is:inline>
      if ('serviceWorker' in navigator) {
        window.addEventListener('load', function() {
          navigator.serviceWorker.register('/sw.js')
            .then(function(registration) {
              console.log('SW registrado:', registration.scope);
            })
            .catch(function(error) {
              console.log('SW registro fallГі:', error);
            });
        });
      }
    </script>
  </body>
</html>
