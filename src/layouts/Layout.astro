---
import '../styles/global.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import ThemeDecorations from '../components/ThemeDecorations.astro';

interface Props {
  title: string;
  description?: string;
  ogImage?: string;
}

const {
  title,
  description = "El Rey de los Pescados y Mariscos - Más de 30 años de tradición en el Muelle Pesquero El Mosquero, Puesto 3 y 4, Maiquetía",
  ogImage = "/jose-lg.webp"
} = Astro.props;
const siteUrl = 'https://www.rpym.net';
const currentUrl = new URL(Astro.url.pathname, siteUrl).href;
const ogImageUrl = new URL(ogImage, siteUrl).href;
---

<!doctype html>
<html lang="es" data-theme="ocean">
  <head>
    <meta charset="UTF-8" />

    <!-- Theme initialization (prevent FOUC) -->
    <script is:inline>
      (function() {
        try {
          var VALID_THEMES = ['ocean','carnival','christmas','easter','valentine','mundial','halloween','campeones','ramos','cuaresma','jueves-santo','viernes-santo','sabado-santo','resurreccion','luto'];
          var cached = localStorage.getItem('rpym_theme');
          if (cached && VALID_THEMES.includes(cached)) {
            document.documentElement.setAttribute('data-theme', cached);
          }

          // ===== MUNDIAL: 48 selecciones, paleta por sesión =====
          // Se define como API global (window.rpymMundial) para que el polling de
          // tema y el banner cliqueable puedan re-aplicar/sortear el equipo sin recargar.
          (function() {
            // Utilidades de color HSL ↔ hex
            function h2hsl(hex) {
              var r=parseInt(hex.slice(1,3),16)/255,g=parseInt(hex.slice(3,5),16)/255,b=parseInt(hex.slice(5,7),16)/255;
              var mx=Math.max(r,g,b),mn=Math.min(r,g,b),h,s,l=(mx+mn)/2;
              if(mx===mn){h=s=0;}else{var d=mx-mn;s=l>.5?d/(2-mx-mn):d/(mx+mn);switch(mx){case r:h=(g-b)/d+(g<b?6:0);break;case g:h=(b-r)/d+2;break;default:h=(r-g)/d+4;}h/=6;}
              return [h*360,s*100,l*100];
            }
            function hsl2h(h,s,l) {
              s/=100;l/=100;var a=s*Math.min(l,1-l);
              var f=function(n){var k=(n+h/30)%12;return Math.round((l-a*Math.max(Math.min(k-3,9-k,1),-1))*255);};
              return '#'+[f(0),f(8),f(4)].map(function(v){return v.toString(16).padStart(2,'0');}).join('');
            }
            // Luminosidades fijas tipo Tailwind: el color del equipo solo define HUE
            // y saturación, garantizando que primary-500 siempre sea un tono medio
            // legible sin importar si el color base es muy oscuro (azul marino, gris).
            function genP(hex) {
              var c=h2hsl(hex),h=c[0],s=c[1];
              var sat = s<12 ? 6 : Math.min(92, Math.max(42, s));
              var ls=[97,93,86,76,64,53,45,37,30,23,16];
              return ls.map(function(li){return hsl2h(h,sat,li);});
            }
            function genA(hex) {
              var c=h2hsl(hex),h=c[0],s=c[1];
              var sat = s<12 ? 8 : Math.min(95, Math.max(48, s));
              var ls=[93,72,61,51,42];
              return ls.map(function(li){return hsl2h(h,sat,li);});
            }

            // [id, nombre, bandera, colorPrimario, colorAcento, textoSobrePrimario, bgDesde, bgHasta]
            // colorPrimario/colorAcento = colores de camiseta (jersey) actual/histórico.
            // textoSobrePrimario: '#fff' o '#1a1a1a' — elegido por máximo contraste WCAG
            // (verificado: todos los equipos ≥4.5 AA normal en botón, banner y LED).
            // 48 selecciones CLASIFICADAS al Mundial 2026 (Canadá/México/EE.UU.)
            var T=[
              // CONMEBOL (6)
              ['argentina','Argentina','🇦🇷','#3788C8','#F6B40E','#fff','#EBF5FB','#FEF9E7'],
              ['brazil','Brasil','🇧🇷','#FEDF00','#009C3B','#1a1a1a','#FFFDE7','#E8F5E9'],
              ['uruguay','Uruguay','🇺🇾','#4DA8D8','#001A72','#fff','#E3F2FD','#EFF6FF'],
              ['colombia','Colombia','🇨🇴','#FCD116','#003087','#1a1a1a','#FFFDE7','#E8EAF6'],
              ['ecuador','Ecuador','🇪🇨','#FFDD00','#003DA5','#1a1a1a','#FFFDE7','#E3F2FD'],
              ['paraguay','Paraguay','🇵🇾','#CE2028','#003893','#fff','#FFEBEE','#E8EAF6'],
              // UEFA (16)
              ['france','Francia','🇫🇷','#002395','#ED2939','#fff','#E8EAF6','#FFEBEE'],
              ['germany','Alemania','🇩🇪','#D00000','#FFCE00','#fff','#FFEBEE','#FFFDE7'],
              ['spain','España','🇪🇸','#C60B1E','#FFC400','#fff','#FFEBEE','#FFFDE7'],
              ['england','Inglaterra','🇬🇧','#1B3A6B','#CF142B','#fff','#E3F2FD','#FFEBEE'],
              ['portugal','Portugal','🇵🇹','#BA0021','#006600','#fff','#FFEBEE','#E8F5E9'],
              ['netherlands','Países Bajos','🇳🇱','#D4500A','#003DA5','#fff','#FFF3E0','#E3F2FD'],
              ['belgium','Bélgica','🇧🇪','#EF3340','#F0A500','#fff','#FFEBEE','#FFF8E1'],
              ['croatia','Croacia','🇭🇷','#CC0000','#172983','#fff','#FFEBEE','#E8EAF6'],
              ['switzerland','Suiza','🇨🇭','#CF0A2C','#3D3D3D','#fff','#FFEBEE','#F5F5F5'],
              ['austria','Austria','🇦🇹','#ED2939','#C4A020','#fff','#FFEBEE','#FFFDE7'],
              ['scotland','Escocia','🏴󠁧󠁢󠁳󠁣󠁴󠁿','#003380','#C8A800','#fff','#E3F2FD','#FFFDE7'],
              ['turkey','Turquía','🇹🇷','#E30A17','#002868','#fff','#FFEBEE','#E3F2FD'],
              ['norway','Noruega','🇳🇴','#BA0C2F','#00205B','#fff','#FFEBEE','#E3F2FD'],
              ['sweden','Suecia','🇸🇪','#FFCD00','#006AA7','#1a1a1a','#FFFDE7','#E3F2FD'],
              ['czechia','Chequia','🇨🇿','#D7141A','#11457E','#fff','#FFEBEE','#E3F2FD'],
              ['bosnia','Bosnia','🇧🇦','#004A99','#FFD100','#fff','#E3F2FD','#FFFDE7'],
              // CONCACAF (6)
              ['usa','EE. UU.','🇺🇸','#002868','#BF0A30','#fff','#E3F2FD','#FFEBEE'],
              ['mexico','México','🇲🇽','#006847','#CE1126','#1a1a1a','#E8F5E9','#FFEBEE'],
              ['canada','Canadá','🇨🇦','#CC0000','#222222','#fff','#FFEBEE','#F5F5F5'],
              ['panama','Panamá','🇵🇦','#DA121A','#005293','#fff','#FFEBEE','#E3F2FD'],
              ['haiti','Haití','🇭🇹','#00209F','#D21034','#fff','#E3F2FD','#FFEBEE'],
              ['curacao','Curazao','🇨🇼','#002B7F','#FDD116','#fff','#E3F2FD','#FFFDE7'],
              // CAF (10)
              ['morocco','Marruecos','🇲🇦','#C1272D','#006233','#fff','#FFEBEE','#E8F5E9'],
              ['senegal','Senegal','🇸🇳','#00853F','#DF0D15','#1a1a1a','#E8F5E9','#FFEBEE'],
              ['ghana','Ghana','🇬🇭','#006B3F','#E8B800','#1a1a1a','#E8F5E9','#FFFDE7'],
              ['ivory_coast','Costa de Marfil','🇨🇮','#D4671E','#009A17','#fff','#FFF3E0','#E8F5E9'],
              ['algeria','Argelia','🇩🇿','#006233','#D21034','#1a1a1a','#E8F5E9','#FFEBEE'],
              ['egypt','Egipto','🇪🇬','#CE1126','#C4A020','#fff','#FFEBEE','#FFFDE7'],
              ['south_africa','Sudáfrica','🇿🇦','#FFB81C','#007A4D','#1a1a1a','#FFF8E1','#E8F5E9'],
              ['tunisia','Túnez','🇹🇳','#E70013','#9E1B32','#fff','#FFEBEE','#FCE4EC'],
              ['cape_verde','Cabo Verde','🇨🇻','#003893','#CF2027','#fff','#E3F2FD','#FFEBEE'],
              ['dr_congo','RD Congo','🇨🇩','#007FFF','#CE1021','#fff','#E1F5FE','#FFEBEE'],
              // AFC (9)
              ['japan','Japón','🇯🇵','#1A237E','#BC002D','#fff','#E8EAF6','#FFEBEE'],
              ['south_korea','Corea del Sur','🇰🇷','#CD2E3A','#003478','#fff','#FFEBEE','#E3F2FD'],
              ['saudi_arabia','Arabia Saudita','🇸🇦','#006C35','#D4A800','#1a1a1a','#E8F5E9','#FFFDE7'],
              ['iran','Irán','🇮🇷','#239F40','#DA0000','#1a1a1a','#E8F5E9','#FAFAFA'],
              ['australia','Australia','🇦🇺','#C49A00','#00843D','#1a1a1a','#FFF8E1','#E8F5E9'],
              ['qatar','Catar','🇶🇦','#8D1B3D','#C4A020','#fff','#FCE4EC','#FFFDE7'],
              ['iraq','Irak','🇮🇶','#0A6B3B','#CE1126','#1a1a1a','#E8F5E9','#FFEBEE'],
              ['jordan','Jordania','🇯🇴','#C8102E','#007A3D','#fff','#FFF5F5','#FAFAFA'],
              ['uzbekistan','Uzbekistán','🇺🇿','#009FCE','#1EB53A','#1a1a1a','#E1F5FE','#E8F5E9'],
              // OFC (1)
              ['new_zealand','Nueva Zelanda','🇳🇿','#1A1A1A','#9DA3A9','#fff','#F4F4F5','#FAFAFA']
            ];

            function findTeam(id) {
              for(var i=0;i<T.length;i++){ if(T[i][0]===id) return T[i]; }
              return null;
            }
            // Selecciones deshabilitadas (eliminadas del Mundial): se guardan en
            // localStorage como JSON de ids para poder filtrar de forma síncrona en
            // el primer pintado, sin esperar al fetch del poll.
            var DKEY = 'rpym_mundial_disabled';
            function getDisabled() {
              try { var v = JSON.parse(localStorage.getItem(DKEY) || '[]'); return Array.isArray(v) ? v : []; }
              catch(e) { return []; }
            }
            function isDisabled(id) { return getDisabled().indexOf(id) !== -1; }
            // Equipos seleccionables (no deshabilitados). Si todos estuvieran
            // deshabilitados, se devuelve la lista completa como salvaguarda.
            function enabledTeams() {
              var d = getDisabled();
              var out = T.filter(function(t){ return d.indexOf(t[0]) === -1; });
              return out.length ? out : T;
            }
            function pickRandom(avoidId) {
              var pool = enabledTeams();
              var team;
              do { team = pool[Math.floor(Math.random() * pool.length)]; }
              while (pool.length > 1 && team[0] === avoidId);
              return team;
            }
            function paint(team) {
              var ps = genP(team[3]), as = genA(team[4]);
              var root = document.documentElement;
              var pk=['--theme-primary-50','--theme-primary-100','--theme-primary-200','--theme-primary-300','--theme-primary-400','--theme-primary-500','--theme-primary-600','--theme-primary-700','--theme-primary-800','--theme-primary-900','--theme-primary-950'];
              var ak=['--theme-accent-100','--theme-accent-300','--theme-accent-400','--theme-accent-500','--theme-accent-600'];
              for(var pi=0;pi<pk.length;pi++) root.style.setProperty(pk[pi], ps[pi]);
              for(var ai=0;ai<ak.length;ai++) root.style.setProperty(ak[ai], as[ai]);
              root.style.setProperty('--theme-primary-fg', team[5]);
              // Gradiente de botón adaptativo: equipos con texto oscuro (verde/dorado,
              // perceptualmente claros) usan p600→p700; los de texto blanco usan p700→p800.
              // Garantiza ≥4.5 (AA normal) en ambos extremos del gradiente.
              var darkFg = (team[5] !== '#fff');
              root.style.setProperty('--btn-from', darkFg ? ps[6] : ps[7]);
              root.style.setProperty('--btn-to',   darkFg ? ps[7] : ps[8]);
              root.style.setProperty('--btn-text-shadow', darkFg ? 'none' : '0 1px 2px rgba(0,0,0,0.3)');
              root.style.setProperty('--theme-bg-from', team[6]);
              root.style.setProperty('--theme-bg-to', team[7]);
              root.setAttribute('data-mundial-team', team[1]);
              root.setAttribute('data-mundial-flag', team[2]);
              root.setAttribute('data-mundial-id', team[0]);
            }
            // apply(forceNew): si forceNew, sortea un equipo distinto al actual;
            // si no, reutiliza el de la sesión (o sortea uno la primera vez).
            // Las selecciones deshabilitadas se excluyen del sorteo, y si la de la
            // sesión quedó deshabilitada se reemplaza por otra habilitada.
            function apply(forceNew) {
              var current = sessionStorage.getItem('rpym_mundial_team');
              var team = null;
              if (!forceNew && current && !isDisabled(current)) team = findTeam(current);
              if (!team) {
                team = pickRandom(current);
                sessionStorage.setItem('rpym_mundial_team', team[0]);
              }
              paint(team);
              return team;
            }

            // set(id): selecciona un equipo específico de los 48 y lo fija en la sesión.
            function set(id) {
              var team = findTeam(id);
              if (!team) return null;
              sessionStorage.setItem('rpym_mundial_team', team[0]);
              paint(team);
              return team;
            }

            // setDisabled(arr): actualiza la lista de selecciones deshabilitadas
            // (llamado por el poll de tema). Si el equipo actual quedó deshabilitado
            // y el tema mundial está activo, re-sortea uno habilitado al vuelo.
            function setDisabled(arr) {
              var list = Array.isArray(arr) ? arr.filter(function(x){ return typeof x === 'string'; }) : [];
              localStorage.setItem(DKEY, JSON.stringify(list));
              if (document.documentElement.getAttribute('data-theme') === 'mundial') {
                var current = sessionStorage.getItem('rpym_mundial_team');
                if (current && isDisabled(current)) apply(true);
              }
            }
            window.rpymMundial = { apply: apply, set: set, setDisabled: setDisabled, teams: T, enabledTeams: enabledTeams, isDisabled: isDisabled };
            if (cached === 'mundial') apply(false);
          })();
        } catch (e) {}
      })();
    </script>
    <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover" />
    <meta name="description" content={description} />
    <meta name="theme-color" content="#0c4a6e" />
    <meta name="robots" content="index, follow" />

    <!-- Canonical -->
    <link rel="canonical" href={currentUrl} />

    <!-- Open Graph -->
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:locale" content="es_VE" />
    <meta property="og:url" content={currentUrl} />
    <meta property="og:site_name" content="RPYM - El Rey de los Pescados y Mariscos" />
    <meta property="og:image" content={ogImageUrl} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content="RPYM - El Rey de los Pescados y Mariscos" />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageUrl} />

    <!-- DNS Prefetch para recursos externos -->
    <link rel="dns-prefetch" href="https://fonts.googleapis.com" />
    <link rel="dns-prefetch" href="https://fonts.gstatic.com" />

    <!-- Preconnect para Google Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />

    <!-- Preload imagen principal del hero -->
    <link rel="preload" as="image" href="/jose-lg.webp" type="image/webp" media="(min-width: 769px)" />
    <link rel="preload" as="image" href="/jose-md.webp" type="image/webp" media="(max-width: 768px)" />

    <!-- Google Fonts con display swap -->
    <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@400;600;700&family=Inter:wght@300;400;500;600&display=swap" rel="stylesheet" />

    <!-- Favicons -->
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" type="image/x-icon" href="/favicon.ico" />
    <link rel="icon" type="image/png" sizes="32x32" href="/icons/favicon-32x32.png" />
    <link rel="icon" type="image/png" sizes="16x16" href="/icons/favicon-16x16.png" />

    <!-- PWA Manifest -->
    <link rel="manifest" href="/manifest.json" />

    <!-- Apple PWA Meta Tags -->
    <meta name="apple-mobile-web-app-capable" content="yes" />
    <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent" />
    <meta name="apple-mobile-web-app-title" content="RPYM Admin" />
    <link rel="apple-touch-icon" href="/icons/apple-touch-icon.png" />
    <link rel="apple-touch-icon" sizes="152x152" href="/icons/icon-152x152.png" />
    <link rel="apple-touch-icon" sizes="180x180" href="/icons/apple-touch-icon.png" />
    <link rel="apple-touch-icon" sizes="167x167" href="/icons/icon-152x152.png" />

    <!-- Windows PWA -->
    <meta name="msapplication-TileColor" content="#0c4a6e" />
    <meta name="msapplication-TileImage" content="/icons/icon-144x144.png" />

    <!-- Mobile App Meta -->
    <meta name="mobile-web-app-capable" content="yes" />
    <meta name="application-name" content="RPYM Admin" />
    <meta name="format-detection" content="telephone=no" />

    <title>{title}</title>

    <!-- Schema.org Structured Data -->
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "LocalBusiness",
      "name": "RPYM - El Rey de los Pescados y Mariscos",
      "description": description,
      "url": siteUrl,
      "telephone": "+58-414-2145202",
      "address": {
        "@type": "PostalAddress",
        "streetAddress": "Muelle Pesquero El Mosquero, Puesto 3 y 4",
        "addressLocality": "Maiquetía",
        "addressRegion": "La Guaira",
        "addressCountry": "VE"
      },
      "geo": {
        "@type": "GeoCoordinates",
        "latitude": "10.5936",
        "longitude": "-66.9546"
      },
      "openingHoursSpecification": [
        {
          "@type": "OpeningHoursSpecification",
          "dayOfWeek": ["Tuesday", "Wednesday", "Thursday", "Friday", "Saturday", "Sunday"],
          "opens": "06:00",
          "closes": "14:30"
        }
      ],
      "priceRange": "$$",
      "servesCuisine": "Mariscos",
