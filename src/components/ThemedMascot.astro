---
/**
 * RPYM - Mascota temática
 * Cambia la mascota según el tema activo
 */
interface Props {
  class?: string;
}

const { class: className = '' } = Astro.props;
---

<div class={`themed-mascot ${className}`}>
  <picture>
    <source srcset="/jose-sm.webp" media="(max-width: 400px)" />
    <source srcset="/jose-md.webp" media="(max-width: 768px)" />
    <img
      id="themed-mascot-img"
      src="/jose-lg.webp"
      alt="Mascota de RPYM"
      class="w-56 h-auto md:w-64 lg:w-80 drop-shadow-2xl animate-float object-contain"
      width="500"
      height="750"
      loading="eager"
      fetchpriority="high"
      decoding="async"
    />
  </picture>
</div>

<style>
  /* Mundial: dimensionado por alto (no por ancho) para tamaño visual uniforme,
     ya que las imágenes están normalizadas a una misma altura de sujeto. */
  .themed-mascot img.is-mundial {
    width: auto !important;
    height: 15rem;
    max-width: 90vw;
  }
  @media (min-width: 768px) {
    .themed-mascot img.is-mundial { height: 17rem; }
  }
  @media (min-width: 1024px) {
    .themed-mascot img.is-mundial { height: 21rem; }
  }
</style>

<script is:inline>
(function() {
  // Versión global de las imágenes /mundial/. Bumpear este número al reemplazar
  // cualquier .webp de mascota mundial — la URL cambia (?v=N) y se invalida
  // cualquier caché envenenado (navegador, CDN, Apple Private Relay, VPN).
  const MUNDIAL_IMAGES_VERSION = 2;

  // Mapeo de tema a mascota multi-tamaño (archivos en /public/)
  const themeMascots = {
    ocean: 'jose',
    carnival: 'carnaval',
    christmas: 'navidad',
    easter: 'jose',
    valentine: 'sanvalentin',
    mundial: 'jose',
    halloween: 'jose',
    campeones: 'campeones'
  };

  // Temas de Semana Santa con imagen única en /mascots/
  const semanaSantaMascots = {
    'ramos': '/mascots/domingoderamos.png',
    'cuaresma': '/mascots/lunesamiercoles.png',
    'jueves-santo': '/mascots/juevessanto.png',
    'resurreccion': '/mascots/domingoderesureccion.png'
  };

  // Temas donde se oculta la mascota
  const hiddenThemes = ['viernes-santo', 'sabado-santo'];

  function updateMascot(theme) {
    const wrapper = document.querySelector('.themed-mascot');
    const img = document.getElementById('themed-mascot-img');
    if (!img || !wrapper) return;

    const picture = img.parentElement;
    if (!picture) return;

    // Ocultar mascota en Viernes y Sábado Santo
    if (hiddenThemes.includes(theme)) {
      wrapper.style.display = 'none';
      return;
    }

    wrapper.style.display = '';

    // Mundial usa imágenes normalizadas por ALTURA (ancho variable): se dimensionan
    // por alto para que todas las selecciones se vean del mismo tamaño.
    img.classList.toggle('is-mundial', theme === 'mundial');

    // Mundial: mascota de la selección activa (imagen única en /mundial/).
    // El id lo fija el script del tema en data-mundial-id al sortear/elegir equipo.
    if (theme === 'mundial') {
      const id = document.documentElement.getAttribute('data-mundial-id');
      const src = id ? `/mundial/${id}.webp?v=${MUNDIAL_IMAGES_VERSION}` : '/jose-lg.webp';
      img.src = src;
      const sources = picture.querySelectorAll('source');
      sources.forEach(source => { source.srcset = src; });
      return;
    }

    // Semana Santa: imagen única desde /mascots/
    if (semanaSantaMascots[theme]) {
      const src = semanaSantaMascots[theme];
      img.src = src;
      const sources = picture.querySelectorAll('source');
      sources.forEach(source => { source.srcset = src; });
      return;
    }

    // Mascota normal con variantes de tamaño
    const mascot = themeMascots[theme] || 'jose';
    img.src = `/${mascot}-lg.webp`;
    const sources = picture.querySelectorAll('source');
    sources.forEach(source => {
      const media = source.getAttribute('media') || '';
      if (media.includes('400px')) {
        source.srcset = `/${mascot}-sm.webp`;
      } else if (media.includes('768px')) {
        source.srcset = `/${mascot}-md.webp`;
      }
    });
  }

  function init() {
    const theme = document.documentElement.getAttribute('data-theme') || 'ocean';
    updateMascot(theme);
  }

  const observer = new MutationObserver((mutations) => {
    mutations.forEach((mutation) => {
      if (mutation.attributeName === 'data-theme' || mutation.attributeName === 'data-mundial-id') {
        const newTheme = document.documentElement.getAttribute('data-theme') || 'ocean';
        updateMascot(newTheme);
      }
    });
  });

  observer.observe(document.documentElement, {
    attributes: true,
    attributeFilter: ['data-theme', 'data-mundial-id']
  });

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', init);
  } else {
    init();
  }
})();
</script>
