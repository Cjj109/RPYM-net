---
/**
 * RPYM - Decoraciones temáticas
 * Renderiza elementos decorativos animados según el tema activo
 */
---

<div class="theme-decorations" id="theme-decorations" aria-hidden="true">
  <!-- Las decoraciones se insertan dinámicamente via JavaScript -->
</div>

<script is:inline>
(function() {
  const container = document.getElementById('theme-decorations');
  if (!container) return;

  // Configuración de decoraciones por tema
  const decorations = {
    ocean: {
      count: 8,
      create: (i) => {
        const bubble = document.createElement('div');
        bubble.className = 'bubble';
        bubble.style.left = `${Math.random() * 100}%`;
        bubble.style.animationDuration = `${8 + Math.random() * 12}s`;
        bubble.style.animationDelay = `${Math.random() * 10}s`;
        bubble.style.width = `${10 + Math.random() * 20}px`;
        bubble.style.height = bubble.style.width;
        bubble.style.opacity = `${0.3 + Math.random() * 0.4}`;
        return bubble;
      }
    },
    carnival: {
      count: 28,
      create: (i) => {
        const colors = ['#a855f7', '#eab308', '#22c55e', '#ec4899', '#f97316'];
        const element = document.createElement('div');
        const type = i % 8;

        if (type < 5) {
          element.className = 'confetti-piece';
          element.style.backgroundColor = colors[i % colors.length];
          element.style.borderRadius = Math.random() > 0.5 ? '50%' : '2px';
          element.style.width = `${6 + Math.random() * 8}px`;
          element.style.height = `${6 + Math.random() * 8}px`;
          element.style.opacity = `${0.65 + Math.random() * 0.3}`;
          const drift = -14 + Math.random() * 28;
          element.style.setProperty('--confetti-drift', `${drift}px`);
          element.style.animation = `confetti-fall ${7 + Math.random() * 5}s linear ${Math.random() * 7}s infinite, confetti-spin ${4 + Math.random() * 2.5}s linear ${Math.random() * 2}s infinite`;
        } else if (type < 7) {
          element.className = 'carnival-streamer';
          element.style.setProperty('--streamer-color', colors[i % colors.length]);
          element.style.setProperty('--streamer-length', `${32 + Math.random() * 22}px`);
          element.style.setProperty('--streamer-width', `${4 + Math.random() * 3}px`);
          element.style.opacity = `${0.45 + Math.random() * 0.25}`;
          element.style.animation = `streamer-fall ${10 + Math.random() * 6}s linear ${Math.random() * 8}s infinite, streamer-swing ${4.2 + Math.random() * 2.2}s ease-in-out ${Math.random() * 2}s infinite`;
        } else {
          element.className = 'carnival-mask';
          element.style.setProperty('--mask-color', colors[i % colors.length]);
          element.style.setProperty('--mask-size', `${14 + Math.random() * 10}px`);
          element.style.opacity = `${0.42 + Math.random() * 0.22}`;
          element.style.animation = `mask-float ${11 + Math.random() * 6}s linear ${Math.random() * 9}s infinite, mask-tilt ${5 + Math.random() * 2}s ease-in-out ${Math.random() * 2}s infinite`;
        }

        element.style.left = `${Math.random() * 100}%`;
        return element;
      }
    },
    christmas: {
      count: 30,
      create: (i) => {
        const element = document.createElement('div');
        // Variedad de elementos: copos (60%), esferas rojas (15%), esferas verdes (15%), estrellas (10%)
        const type = i % 10;
        if (type < 6) {
          // Copos de nieve (tipos variados)
          element.className = i % 3 === 0 ? 'snowflake-star' : 'snowflake';
          const size = 6 + Math.random() * 10;
          element.style.setProperty('--snow-size', `${size}px`);
        } else if (type < 7) {
          // Esferas rojas
          element.className = 'christmas-ornament';
          const size = 8 + Math.random() * 6;
          element.style.setProperty('--ornament-size', `${size}px`);
        } else if (type < 8) {
          // Esferas verdes
          element.className = 'christmas-ornament-green';
          const size = 8 + Math.random() * 6;
          element.style.setProperty('--ornament-size', `${size}px`);
        } else {
          // Estrellas doradas
          element.className = 'christmas-star';
          const size = 10 + Math.random() * 8;
          element.style.setProperty('--star-size', `${size}px`);
        }
        element.style.left = `${Math.random() * 100}%`;
        element.style.opacity = `${0.6 + Math.random() * 0.4}`;
        const duration = 8 + Math.random() * 10;
        const delay = Math.random() * 6;
        element.style.animation = `snowfall ${duration}s linear ${delay}s infinite, snow-sway 3s ease-in-out ${delay}s infinite`;
        return element;
      }
    },
    easter: {
      count: 0,
      create: () => document.createElement('div'),
    },
    valentine: {
      count: 28,
      create: (i) => {
        const element = document.createElement('div');
        const colors = ['#e11d48', '#f43f5e', '#fb7185', '#fda4af', '#be123c'];
        const type = i % 7;
        const delay = Math.random() * 6;
        const duration = 6 + Math.random() * 7;

        if (type < 5) {
          element.className = 'valentine-heart';
          const size = 10 + Math.random() * 13;
          element.style.setProperty('--heart-size', `${size}px`);
          element.style.setProperty('--heart-color', colors[i % colors.length]);
          element.style.opacity = `${0.38 + Math.random() * 0.35}`;
          element.style.animation = `heart-fall ${duration}s linear ${delay}s infinite, heart-sway 4s ease-in-out ${delay}s infinite, heart-glow 2.4s ease-in-out ${delay}s infinite`;
        } else if (type === 5) {
          element.className = 'valentine-spark';
          element.style.setProperty('--spark-size', `${8 + Math.random() * 8}px`);
          element.style.setProperty('--spark-color', ['#fda4af', '#fbcfe8', '#fef3c7'][i % 3]);
          element.style.opacity = `${0.35 + Math.random() * 0.3}`;
          element.style.animation = `spark-fall ${7 + Math.random() * 6}s linear ${delay}s infinite, spark-twinkle ${1.7 + Math.random() * 1.4}s ease-in-out ${delay}s infinite`;
        } else {
          element.className = 'valentine-petal';
          element.style.setProperty('--petal-size', `${9 + Math.random() * 9}px`);
          element.style.setProperty('--petal-color', ['#fb7185', '#f43f5e', '#fda4af'][i % 3]);
          element.style.opacity = `${0.3 + Math.random() * 0.3}`;
          element.style.animation = `petal-fall ${8 + Math.random() * 6}s linear ${delay}s infinite, petal-spin ${2.2 + Math.random() * 1.5}s ease-in-out ${delay}s infinite`;
        }

        element.style.left = `${Math.random() * 100}%`;
        return element;
      }
    },
    mundial: {
      count: 10,
      create: (i) => {
        const element = document.createElement('div');
        // Variedad: balones (50%), trofeos (10%), confeti verde (20%), confeti dorado (20%)
        const type = i % 10;
        if (type < 5) {
          // Balones de fútbol
          element.className = 'mundial-ball';
          const size = 12 + Math.random() * 8;
          element.style.setProperty('--ball-size', `${size}px`);
        } else if (type < 6) {
          // Trofeos
          element.className = 'mundial-trophy';
          const size = 12 + Math.random() * 6;
          element.style.setProperty('--trophy-size', `${size}px`);
        } else if (type < 8) {
          // Confeti verde
          element.className = 'mundial-confetti green';
          const size = 6 + Math.random() * 6;
          element.style.setProperty('--confetti-size', `${size}px`);
        } else {
          // Confeti dorado
          element.className = 'mundial-confetti gold';
          const size = 6 + Math.random() * 6;
          element.style.setProperty('--confetti-size', `${size}px`);
        }
        element.style.left = `${Math.random() * 100}%`;
        element.style.opacity = `${0.6 + Math.random() * 0.4}`;
        const duration = 7 + Math.random() * 6;
        const delay = Math.random() * 6;
        element.style.animation = `mundial-fall ${duration}s linear ${delay}s infinite`;
        return element;
      }
    },
    campeones: {
      count: 18,
      create: (i) => {
        const element = document.createElement('div');
        const type = i % 10;
        const delay = Math.random() * 6;
        const duration = 6 + Math.random() * 6;

        if (type < 2) {
          // Confetti amarillo
          element.className = 'campeones-confetti yellow';
          element.style.setProperty('--confetti-size', `${6 + Math.random() * 8}px`);
          element.style.borderRadius = Math.random() > 0.5 ? '50%' : '2px';
        } else if (type < 4) {
          // Confetti azul
          element.className = 'campeones-confetti blue';
          element.style.setProperty('--confetti-size', `${6 + Math.random() * 8}px`);
          element.style.borderRadius = Math.random() > 0.5 ? '50%' : '2px';
        } else if (type < 6) {
          // Confetti rojo
          element.className = 'campeones-confetti red';
          element.style.setProperty('--confetti-size', `${6 + Math.random() * 8}px`);
          element.style.borderRadius = Math.random() > 0.5 ? '50%' : '2px';
        } else if (type < 7) {
          // Pelota de béisbol
          element.className = 'campeones-baseball';
          element.style.setProperty('--ball-size', `${10 + Math.random() * 8}px`);
        } else if (type < 8) {
          // Estrella dorada
          element.className = 'campeones-star';
          element.style.setProperty('--star-size', `${10 + Math.random() * 8}px`);
        } else if (type < 9) {
          // Trofeo
          element.className = 'campeones-trophy';
          element.style.setProperty('--trophy-size', `${12 + Math.random() * 6}px`);
        } else {
          // Bandera venezolana
          element.className = 'campeones-flag';
          element.style.setProperty('--flag-size', `${10 + Math.random() * 6}px`);
        }

        element.style.left = `${Math.random() * 100}%`;
        element.style.opacity = `${0.6 + Math.random() * 0.35}`;
        element.style.animation = `campeones-fall ${duration}s linear ${delay}s infinite, campeones-drift ${3 + Math.random() * 3}s ease-in-out ${delay}s infinite`;
        return element;
      }
    },
    halloween: {
      count: 15,
      create: (i) => {
        const element = document.createElement('div');
        // Alternar entre murciélagos y calabazas
        element.className = i % 3 === 0 ? 'halloween-pumpkin' : 'halloween-bat';
        const size = element.className === 'halloween-pumpkin' ? (10 + Math.random() * 8) : (12 + Math.random() * 8);
        element.style.setProperty(element.className === 'halloween-pumpkin' ? '--pumpkin-size' : '--bat-size', `${size}px`);
        element.style.left = `${Math.random() * 100}%`;
        element.style.opacity = `${0.6 + Math.random() * 0.3}`;
        const duration = 6 + Math.random() * 6;
        const delay = Math.random() * 5;
        element.style.animation = `halloween-fall ${duration}s linear ${delay}s infinite, halloween-flutter 2s ease-in-out ${delay}s infinite`;
        return element;
      }
    },

    // === SEMANA SANTA ===
    // Sin partículas — detalles estáticos en CSS (bordes, glows, amanecer)

    ramos: {
      count: 7,
      create: (i) => {
        const element = document.createElement('div');
        element.className = 'palm-frond';
        const rotation = -30 + Math.random() * 60;
        element.style.setProperty('--palm-rotation', `${rotation}deg`);
        element.style.left = `${5 + Math.random() * 90}%`;
        element.style.opacity = `${0.55 + Math.random() * 0.35}`;
        const duration = 9 + Math.random() * 7;
        const delay = Math.random() * 8;
        element.style.animation = `palm-fall ${duration}s linear ${delay}s infinite, palm-sway ${2.5 + Math.random() * 2.5}s ease-in-out ${delay}s infinite`;
        return element;
      }
    },

    cuaresma: {
      count: 0,
      create: () => document.createElement('span')
    },

    'jueves-santo': {
      count: 0,
      create: () => document.createElement('span')
    },

    'viernes-santo': {
      count: 0,
      create: () => document.createElement('span')
    },

    'sabado-santo': {
      count: 0,
      create: () => document.createElement('span')
    },

    resurreccion: {
      count: 0,
      create: () => document.createElement('span')
    }
  };

  let currentTheme = null;

  function renderDecorations(theme) {
    // Solo re-renderizar si el tema cambió
    if (currentTheme === theme) return;
    currentTheme = theme;

    // Limpiar decoraciones anteriores
    container.innerHTML = '';

    const config = decorations[theme];
    if (!config) return;

    // Crear nuevas decoraciones
    for (let i = 0; i < config.count; i++) {
      const element = config.create(i);
      container.appendChild(element);
    }
  }

  // ===== BANNER EQUIPO MUNDIAL =====
  function renderMundialBanner() {
    const existing = document.getElementById('mundial-team-banner');
    const theme = document.documentElement.getAttribute('data-theme');
    const teamName = document.documentElement.getAttribute('data-mundial-team');
    const teamFlag = document.documentElement.getAttribute('data-mundial-flag');

    if (theme !== 'mundial' || !teamName) {
      if (existing) existing.remove();
      return;
    }

    // Contenido: bandera + nombre + ícono de "sortear otro equipo"
    function fillBanner(el) {
      const name = document.documentElement.getAttribute('data-mundial-team');
      const flag = document.documentElement.getAttribute('data-mundial-flag');
      el.innerHTML = `<span style="font-size:18px;line-height:1">${flag}</span><span>${name}</span><span aria-hidden="true" style="font-size:13px;opacity:0.7;margin-left:2px">⇄</span>`;
    }

    if (existing) { fillBanner(existing); return; } // ya existe: solo actualizar

    const banner = document.createElement('div');
    banner.id = 'mundial-team-banner';
    banner.title = 'Tocar para cambiar · mantener presionado para elegir';
    banner.setAttribute('role', 'button');
    banner.setAttribute('tabindex', '0');
    fillBanner(banner);
    banner.style.cssText = [
      'position:fixed',
      'bottom:20px',
      'right:20px',
      'z-index:9999',
      'display:flex',
      'align-items:center',
      'gap:6px',
      'background:var(--theme-primary-900)',
      'color:#fff',
      'padding:6px 14px 6px 10px',
      'border-radius:24px',
      'font-size:13px',
      'font-weight:600',
      'border:1px solid var(--theme-primary-700)',
      'box-shadow:0 2px 12px rgba(0,0,0,0.2)',
      'cursor:pointer',
      'user-select:none',
      '-webkit-tap-highlight-color:transparent',
      'font-family:var(--font-body)',
      'letter-spacing:0.02em',
      'opacity:0',
      'transition:opacity 0.4s ease, transform 0.15s ease',
    ].join(';');

    function bump() {
      banner.style.transform = 'scale(0.92)';
      setTimeout(() => { banner.style.transform = 'scale(1)'; }, 150);
    }
    function shuffle() {
      if (!window.rpymMundial) return;
      window.rpymMundial.apply(true); // sortea un equipo distinto (recolorea vía CSS vars)
      fillBanner(banner);
      bump();
    }

    // ===== SELECTOR DE LAS 48 SELECCIONES (mantener presionado / clic derecho) =====
    function openPicker() {
      if (document.getElementById('mundial-team-picker')) return;
      const teams = (window.rpymMundial && window.rpymMundial.teams) || [];
      const current = document.documentElement.getAttribute('data-mundial-team');

      const overlay = document.createElement('div');
      overlay.id = 'mundial-team-picker';
      overlay.style.cssText = [
        'position:fixed','inset:0','z-index:10000',
        'display:flex','align-items:center','justify-content:center',
        'background:rgba(0,0,0,0.5)','padding:20px',
        'opacity:0','transition:opacity 0.2s ease',
        '-webkit-tap-highlight-color:transparent',
      ].join(';');

      const panel = document.createElement('div');
      panel.style.cssText = [
        'background:#fff','color:#1a1a1a','border-radius:16px',
        'max-width:520px','width:100%','max-height:80vh','overflow:hidden',
        'display:flex','flex-direction:column',
        'box-shadow:0 12px 40px rgba(0,0,0,0.3)',
        'transform:scale(0.96)','transition:transform 0.2s ease',
        'font-family:var(--font-body)',
      ].join(';');

      const head = document.createElement('div');
      head.style.cssText = 'padding:14px 18px;border-bottom:1px solid #eee;display:flex;align-items:center;justify-content:space-between;font-weight:700;font-size:15px';
      head.innerHTML = '<span>Elige una selección</span><span id="mtp-close" role="button" tabindex="0" aria-label="Cerrar" style="cursor:pointer;font-size:22px;line-height:1;opacity:0.55;padding:0 4px">&times;</span>';

      const grid = document.createElement('div');
      grid.style.cssText = 'overflow-y:auto;padding:12px;display:grid;grid-template-columns:repeat(auto-fill,minmax(140px,1fr));gap:8px';

      function closePicker() {
        overlay.style.opacity = '0';
        setTimeout(() => { if (overlay.parentNode) overlay.parentNode.removeChild(overlay); }, 200);
        document.removeEventListener('keydown', onKey);
      }
      function onKey(e) { if (e.key === 'Escape') closePicker(); }

      teams.forEach((t) => {
        const item = document.createElement('button');
        const active = t[1] === current;
        item.type = 'button';
        item.style.cssText = [
          'display:flex','align-items:center','gap:8px',
          'padding:8px 10px','border-radius:10px','cursor:pointer',
          'border:1px solid ' + (active ? 'var(--theme-primary-600,#1565c0)' : '#e5e5e5'),
          'background:' + (active ? 'var(--theme-primary-50,#e3f2fd)' : '#fafafa'),
          'font-size:13px','font-weight:600','color:#1a1a1a','text-align:left',
          'font-family:inherit','transition:background 0.15s ease',
        ].join(';');
        item.innerHTML = '<span style="font-size:18px;line-height:1">' + t[2] + '</span><span style="overflow:hidden;text-overflow:ellipsis;white-space:nowrap">' + t[1] + '</span>';
        item.addEventListener('click', () => {
          if (window.rpymMundial && window.rpymMundial.set) window.rpymMundial.set(t[0]);
          fillBanner(banner);
          bump();
          closePicker();
        });
        grid.appendChild(item);
      });

      panel.appendChild(head);
      panel.appendChild(grid);
      overlay.appendChild(panel);
      document.body.appendChild(overlay);
      requestAnimationFrame(() => { overlay.style.opacity = '1'; panel.style.transform = 'scale(1)'; });

      document.addEventListener('keydown', onKey);
      overlay.addEventListener('click', (e) => { if (e.target === overlay) closePicker(); });
      head.querySelector('#mtp-close').addEventListener('click', closePicker);
    }

    // Distinguir toque corto (sortear) de pulsación larga (abrir selector)
    let pressTimer = null, longPressed = false;
    function startPress() {
      longPressed = false;
      pressTimer = setTimeout(() => { longPressed = true; openPicker(); }, 500);
    }
    function cancelPress() { if (pressTimer) { clearTimeout(pressTimer); pressTimer = null; } }
    banner.addEventListener('pointerdown', startPress);
    banner.addEventListener('pointerup', cancelPress);
    banner.addEventListener('pointerleave', cancelPress);
    banner.addEventListener('pointercancel', cancelPress);
    banner.addEventListener('click', (e) => {
      if (longPressed) { longPressed = false; e.preventDefault(); return; }
      shuffle();
    });
    banner.addEventListener('contextmenu', (e) => { e.preventDefault(); openPicker(); });
    banner.addEventListener('keydown', (e) => {
      if (e.key === 'Enter' || e.key === ' ') { e.preventDefault(); shuffle(); }
      else if (e.key === 'ArrowUp' || e.key === 'ArrowDown') { e.preventDefault(); openPicker(); }
    });

    document.body.appendChild(banner);
    requestAnimationFrame(() => { banner.style.opacity = '1'; });
  }

  // Renderizar decoraciones iniciales
  function init() {
    const theme = document.documentElement.getAttribute('data-theme') || 'ocean';
    renderDecorations(theme);
    renderMundialBanner();
  }

  // Observar cambios en el tema
  const observer = new MutationObserver((mutations) => {
    mutations.forEach((mutation) => {
      if (mutation.attributeName === 'data-theme') {
        const newTheme = document.documentElement.getAttribute('data-theme') || 'ocean';
        renderDecorations(newTheme);
        renderMundialBanner();
      }
    });
  });

  observer.observe(document.documentElement, {
    attributes: true,
    attributeFilter: ['data-theme', 'data-mundial-team']
  });

  // Inicializar cuando el DOM esté listo
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', init);
  } else {
    init();
  }
})();
</script>
