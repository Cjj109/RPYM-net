---
/**
 * RPYM - Decoraciones temáticas
 * Renderiza elementos decorativos animados según el tema activo
 */
---

<div class="theme-decorations" id="theme-decorations" aria-hidden="true">
  <!-- Las decoraciones se insertan dinámicamente via JavaScript -->
</div>

<script is:inline>
(function() {
  const container = document.getElementById('theme-decorations');
  if (!container) return;

  // Configuración de decoraciones por tema
  const decorations = {
    ocean: {
      count: 8,
      create: (i) => {
        const bubble = document.createElement('div');
        bubble.className = 'bubble';
        bubble.style.left = `${Math.random() * 100}%`;
        bubble.style.animationDuration = `${8 + Math.random() * 12}s`;
        bubble.style.animationDelay = `${Math.random() * 10}s`;
        bubble.style.width = `${10 + Math.random() * 20}px`;
        bubble.style.height = bubble.style.width;
        bubble.style.opacity = `${0.3 + Math.random() * 0.4}`;
        return bubble;
      }
    },
    carnival: {
      count: 28,
      create: (i) => {
        const colors = ['#a855f7', '#eab308', '#22c55e', '#ec4899', '#f97316'];
        const element = document.createElement('div');
        const type = i % 8;

        if (type < 5) {
          element.className = 'confetti-piece';
          element.style.backgroundColor = colors[i % colors.length];
          element.style.borderRadius = Math.random() > 0.5 ? '50%' : '2px';
          element.style.width = `${6 + Math.random() * 8}px`;
          element.style.height = `${6 + Math.random() * 8}px`;
          element.style.opacity = `${0.65 + Math.random() * 0.3}`;
          const drift = -14 + Math.random() * 28;
          element.style.setProperty('--confetti-drift', `${drift}px`);
          element.style.animation = `confetti-fall ${7 + Math.random() * 5}s linear ${Math.random() * 7}s infinite, confetti-spin ${4 + Math.random() * 2.5}s linear ${Math.random() * 2}s infinite`;
        } else if (type < 7) {
          element.className = 'carnival-streamer';
          element.style.setProperty('--streamer-color', colors[i % colors.length]);
          element.style.setProperty('--streamer-length', `${32 + Math.random() * 22}px`);
          element.style.setProperty('--streamer-width', `${4 + Math.random() * 3}px`);
          element.style.opacity = `${0.45 + Math.random() * 0.25}`;
          element.style.animation = `streamer-fall ${10 + Math.random() * 6}s linear ${Math.random() * 8}s infinite, streamer-swing ${4.2 + Math.random() * 2.2}s ease-in-out ${Math.random() * 2}s infinite`;
        } else {
          element.className = 'carnival-mask';
          element.style.setProperty('--mask-color', colors[i % colors.length]);
          element.style.setProperty('--mask-size', `${14 + Math.random() * 10}px`);
          element.style.opacity = `${0.42 + Math.random() * 0.22}`;
          element.style.animation = `mask-float ${11 + Math.random() * 6}s linear ${Math.random() * 9}s infinite, mask-tilt ${5 + Math.random() * 2}s ease-in-out ${Math.random() * 2}s infinite`;
        }

        element.style.left = `${Math.random() * 100}%`;
        return element;
      }
    },
    christmas: {
      count: 30,
      create: (i) => {
        const element = document.createElement('div');
        // Variedad de elementos: copos (60%), esferas rojas (15%), esferas verdes (15%), estrellas (10%)
        const type = i % 10;
        if (type < 6) {
          // Copos de nieve (tipos variados)
          element.className = i % 3 === 0 ? 'snowflake-star' : 'snowflake';
          const size = 6 + Math.random() * 10;
          element.style.setProperty('--snow-size', `${size}px`);
        } else if (type < 7) {
          // Esferas rojas
          element.className = 'christmas-ornament';
          const size = 8 + Math.random() * 6;
          element.style.setProperty('--ornament-size', `${size}px`);
        } else if (type < 8) {
          // Esferas verdes
          element.className = 'christmas-ornament-green';
          const size = 8 + Math.random() * 6;
          element.style.setProperty('--ornament-size', `${size}px`);
        } else {
          // Estrellas doradas
          element.className = 'christmas-star';
          const size = 10 + Math.random() * 8;
          element.style.setProperty('--star-size', `${size}px`);
        }
        element.style.left = `${Math.random() * 100}%`;
        element.style.opacity = `${0.6 + Math.random() * 0.4}`;
        const duration = 8 + Math.random() * 10;
        const delay = Math.random() * 6;
        element.style.animation = `snowfall ${duration}s linear ${delay}s infinite, snow-sway 3s ease-in-out ${delay}s infinite`;
        return element;
      }
    },
    easter: {
      count: 15,
      create: (i) => {
        const colors = ['#f9a8d4', '#a78bfa', '#86efac', '#fde047', '#67e8f9'];
        const element = document.createElement('div');
        element.className = 'easter-egg';
        const size = 8 + Math.random() * 8;
        element.style.setProperty('--egg-size', `${size}px`);
        element.style.setProperty('--egg-color', colors[i % colors.length]);
        element.style.left = `${Math.random() * 100}%`;
        element.style.opacity = `${0.5 + Math.random() * 0.4}`;
        const duration = 7 + Math.random() * 6;
        const delay = Math.random() * 4;
        element.style.animation = `easter-fall ${duration}s linear ${delay}s infinite, easter-wobble 2s ease-in-out ${delay}s infinite`;
        return element;
      }
    },
    valentine: {
      count: 28,
      create: (i) => {
        const element = document.createElement('div');
        const colors = ['#e11d48', '#f43f5e', '#fb7185', '#fda4af', '#be123c'];
        const type = i % 7;
        const delay = Math.random() * 6;
        const duration = 6 + Math.random() * 7;

        if (type < 5) {
          element.className = 'valentine-heart';
          const size = 10 + Math.random() * 13;
          element.style.setProperty('--heart-size', `${size}px`);
          element.style.setProperty('--heart-color', colors[i % colors.length]);
          element.style.opacity = `${0.38 + Math.random() * 0.35}`;
          element.style.animation = `heart-fall ${duration}s linear ${delay}s infinite, heart-sway 4s ease-in-out ${delay}s infinite, heart-glow 2.4s ease-in-out ${delay}s infinite`;
        } else if (type === 5) {
          element.className = 'valentine-spark';
          element.style.setProperty('--spark-size', `${8 + Math.random() * 8}px`);
          element.style.setProperty('--spark-color', ['#fda4af', '#fbcfe8', '#fef3c7'][i % 3]);
          element.style.opacity = `${0.35 + Math.random() * 0.3}`;
          element.style.animation = `spark-fall ${7 + Math.random() * 6}s linear ${delay}s infinite, spark-twinkle ${1.7 + Math.random() * 1.4}s ease-in-out ${delay}s infinite`;
        } else {
          element.className = 'valentine-petal';
          element.style.setProperty('--petal-size', `${9 + Math.random() * 9}px`);
          element.style.setProperty('--petal-color', ['#fb7185', '#f43f5e', '#fda4af'][i % 3]);
          element.style.opacity = `${0.3 + Math.random() * 0.3}`;
          element.style.animation = `petal-fall ${8 + Math.random() * 6}s linear ${delay}s infinite, petal-spin ${2.2 + Math.random() * 1.5}s ease-in-out ${delay}s infinite`;
        }

        element.style.left = `${Math.random() * 100}%`;
        return element;
      }
    },
    mundial: {
      count: 20,
      create: (i) => {
        const element = document.createElement('div');
        // Variedad: balones (40%), estrellas (20%), trofeos (15%), confeti verde (15%), confeti dorado (10%)
        const type = i % 10;
        if (type < 4) {
          // Balones de fútbol
          element.className = 'mundial-ball';
          const size = 12 + Math.random() * 8;
          element.style.setProperty('--ball-size', `${size}px`);
        } else if (type < 6) {
          // Estrellas doradas
          element.className = 'mundial-star';
          const size = 10 + Math.random() * 8;
          element.style.setProperty('--star-size', `${size}px`);
        } else if (type < 7) {
          // Trofeos
          element.className = 'mundial-trophy';
          const size = 12 + Math.random() * 6;
          element.style.setProperty('--trophy-size', `${size}px`);
        } else if (type < 9) {
          // Confeti verde
          element.className = 'mundial-confetti green';
          const size = 6 + Math.random() * 6;
          element.style.setProperty('--confetti-size', `${size}px`);
        } else {
          // Confeti dorado
          element.className = 'mundial-confetti gold';
          const size = 6 + Math.random() * 6;
          element.style.setProperty('--confetti-size', `${size}px`);
        }
        element.style.left = `${Math.random() * 100}%`;
        element.style.opacity = `${0.6 + Math.random() * 0.4}`;
        const duration = 7 + Math.random() * 6;
        const delay = Math.random() * 6;
        element.style.animation = `mundial-fall ${duration}s linear ${delay}s infinite, mundial-spin 2s ease-in-out ${delay}s infinite`;
        return element;
      }
    },
    campeones: {
      count: 18,
      create: (i) => {
        const element = document.createElement('div');
        const type = i % 10;
        const delay = Math.random() * 6;
        const duration = 6 + Math.random() * 6;

        if (type < 2) {
          // Confetti amarillo
          element.className = 'campeones-confetti yellow';
          element.style.setProperty('--confetti-size', `${6 + Math.random() * 8}px`);
          element.style.borderRadius = Math.random() > 0.5 ? '50%' : '2px';
        } else if (type < 4) {
          // Confetti azul
          element.className = 'campeones-confetti blue';
          element.style.setProperty('--confetti-size', `${6 + Math.random() * 8}px`);
          element.style.borderRadius = Math.random() > 0.5 ? '50%' : '2px';
        } else if (type < 6) {
          // Confetti rojo
          element.className = 'campeones-confetti red';
          element.style.setProperty('--confetti-size', `${6 + Math.random() * 8}px`);
          element.style.borderRadius = Math.random() > 0.5 ? '50%' : '2px';
        } else if (type < 7) {
          // Pelota de béisbol
          element.className = 'campeones-baseball';
          element.style.setProperty('--ball-size', `${10 + Math.random() * 8}px`);
        } else if (type < 8) {
          // Estrella dorada
          element.className = 'campeones-star';
          element.style.setProperty('--star-size', `${10 + Math.random() * 8}px`);
        } else if (type < 9) {
          // Trofeo
          element.className = 'campeones-trophy';
          element.style.setProperty('--trophy-size', `${12 + Math.random() * 6}px`);
        } else {
          // Bandera venezolana
          element.className = 'campeones-flag';
          element.style.setProperty('--flag-size', `${10 + Math.random() * 6}px`);
        }

        element.style.left = `${Math.random() * 100}%`;
        element.style.opacity = `${0.6 + Math.random() * 0.35}`;
        element.style.animation = `campeones-fall ${duration}s linear ${delay}s infinite, campeones-drift ${3 + Math.random() * 3}s ease-in-out ${delay}s infinite`;
        return element;
      }
    },
    halloween: {
      count: 15,
      create: (i) => {
        const element = document.createElement('div');
        // Alternar entre murciélagos y calabazas
        element.className = i % 3 === 0 ? 'halloween-pumpkin' : 'halloween-bat';
        const size = element.className === 'halloween-pumpkin' ? (10 + Math.random() * 8) : (12 + Math.random() * 8);
        element.style.setProperty(element.className === 'halloween-pumpkin' ? '--pumpkin-size' : '--bat-size', `${size}px`);
        element.style.left = `${Math.random() * 100}%`;
        element.style.opacity = `${0.6 + Math.random() * 0.3}`;
        const duration = 6 + Math.random() * 6;
        const delay = Math.random() * 5;
        element.style.animation = `halloween-fall ${duration}s linear ${delay}s infinite, halloween-flutter 2s ease-in-out ${delay}s infinite`;
        return element;
      }
    },

    // === SEMANA SANTA ===

    ramos: {
      count: 36,
      create: (i) => {
        const greenColors = ['#10b981', '#059669', '#047857', '#34d399', '#6ee7b7', '#a7f3d0'];
        const element = document.createElement('div');
        const delay = Math.random() * 10;
        const duration = 8 + Math.random() * 8;

        if (i % 5 < 4) {
          // Hojas esmeralda
          element.className = 'ramos-leaf';
          const size = 9 + Math.random() * 10;
          element.style.setProperty('--leaf-size', `${size}px`);
          element.style.setProperty('--leaf-color', greenColors[i % greenColors.length]);
          element.style.opacity = `${0.55 + Math.random() * 0.4}`;
          element.style.animation = `ramos-fall ${duration}s linear ${delay}s infinite, ramos-sway ${3 + Math.random() * 2}s ease-in-out ${delay}s infinite`;
        } else {
          // Destellos dorados intensos
          element.className = 'ramos-gold';
          const size = 5 + Math.random() * 6;
          element.style.setProperty('--dot-size', `${size}px`);
          element.style.opacity = `${0.7 + Math.random() * 0.3}`;
          element.style.animation = `ramos-fall ${duration - 2}s linear ${delay}s infinite`;
        }

        element.style.left = `${Math.random() * 100}%`;
        return element;
      }
    },

    cuaresma: {
      count: 24,
      create: (i) => {
        const purpleColors = ['#6d28d9', '#7c3aed', '#5b21b6', '#8b5cf6', '#a78bfa', '#4c1d95'];
        const element = document.createElement('div');
        element.className = 'cuaresma-petal';
        const size = 8 + Math.random() * 9;
        element.style.setProperty('--petal-size', `${size}px`);
        element.style.background = `linear-gradient(135deg, ${purpleColors[i % purpleColors.length]}dd, ${purpleColors[(i + 2) % purpleColors.length]}aa)`;
        element.style.left = `${Math.random() * 100}%`;
        element.style.opacity = `${0.45 + Math.random() * 0.35}`;
        const duration = 11 + Math.random() * 9;
        const delay = Math.random() * 11;
        element.style.animation = `cuaresma-fall ${duration}s linear ${delay}s infinite, cuaresma-sway ${4 + Math.random() * 3.5}s ease-in-out ${delay}s infinite`;
        return element;
      }
    },

    'jueves-santo': {
      count: 26,
      create: (i) => {
        const element = document.createElement('div');
        element.className = 'jueves-santo-spark';
        const size = 4 + Math.random() * 7;
        element.style.setProperty('--spark-size', `${size}px`);
        element.style.left = `${Math.random() * 100}%`;
        element.style.opacity = `${0.5 + Math.random() * 0.45}`;
        const duration = 9 + Math.random() * 8;
        const delay = Math.random() * 10;
        element.style.animation = `jueves-santo-fall ${duration}s linear ${delay}s infinite, jueves-santo-glow ${1.8 + Math.random() * 2}s ease-in-out ${delay}s infinite`;
        return element;
      }
    },

    'viernes-santo': {
      // Sin decoraciones — la página está en escala de grises, silencio visual
      count: 0,
      create: () => document.createElement('span')
    },

    'sabado-santo': {
      count: 18,
      create: (i) => {
        const element = document.createElement('div');
        element.className = 'sabado-santo-dust';
        const size = 4 + Math.random() * 5;
        element.style.width = `${size}px`;
        element.style.height = `${size}px`;
        // Mezcla de grises + dorado visible + toque violeta
        const type = i % 5;
        if (type === 0) {
          element.style.background = 'radial-gradient(circle, rgba(253, 224, 71, 0.9), rgba(234, 179, 8, 0.5))';
          element.style.boxShadow = '0 0 4px rgba(234, 179, 8, 0.4)';
        } else if (type === 4) {
          element.style.background = 'radial-gradient(circle, rgba(139, 92, 246, 0.7), rgba(109, 40, 217, 0.3))';
        } else {
          element.style.background = `rgba(${100 + Math.random() * 50}, ${100 + Math.random() * 50}, ${110 + Math.random() * 50}, 0.5)`;
        }
        element.style.left = `${Math.random() * 100}%`;
        element.style.opacity = `${0.3 + Math.random() * 0.3}`;
        const duration = 14 + Math.random() * 10;
        const delay = Math.random() * 12;
        const anim = type === 0 ? `sabado-santo-fall ${duration}s linear ${delay}s infinite, sabado-santo-pulse ${2 + Math.random() * 2}s ease-in-out ${delay}s infinite` : `sabado-santo-fall ${duration}s linear ${delay}s infinite`;
        element.style.animation = anim;
        return element;
      }
    },

    resurreccion: {
      count: 50,
      create: (i) => {
        const element = document.createElement('div');
        const delay = Math.random() * 8;
        const duration = 6 + Math.random() * 7;
        const type = i % 5;

        if (type < 2) {
          // Rayos de luz (blancos → dorados)
          element.className = 'resurreccion-ray';
          element.style.setProperty('--ray-w', `${2 + Math.random() * 4}px`);
          element.style.setProperty('--ray-h', `${16 + Math.random() * 20}px`);
          element.style.opacity = `${0.55 + Math.random() * 0.4}`;
          element.style.animation = `resurreccion-fall ${duration}s linear ${delay}s infinite`;
        } else if (type < 4) {
          // Círculos luminosos dorados/naranjas
          element.className = 'resurreccion-glow';
          const size = 6 + Math.random() * 9;
          element.style.setProperty('--glow-size', `${size}px`);
          element.style.opacity = `${0.6 + Math.random() * 0.35}`;
          element.style.animation = `resurreccion-fall ${duration + 2}s linear ${delay}s infinite, resurreccion-glow ${1.6 + Math.random() * 1.5}s ease-in-out ${delay}s infinite`;
        } else {
          // Chispas blancas brillantes
          element.className = 'resurreccion-spark';
          const size = 3 + Math.random() * 4;
          element.style.setProperty('--spark-size', `${size}px`);
          element.style.opacity = `${0.7 + Math.random() * 0.3}`;
          element.style.animation = `resurreccion-fall ${duration - 1}s linear ${delay}s infinite, resurreccion-glow ${1.2 + Math.random() * 1}s ease-in-out ${delay}s infinite`;
        }

        element.style.left = `${Math.random() * 100}%`;
        return element;
      }
    }
  };

  let currentTheme = null;

  function renderDecorations(theme) {
    // Solo re-renderizar si el tema cambió
    if (currentTheme === theme) return;
    currentTheme = theme;

    // Limpiar decoraciones anteriores
    container.innerHTML = '';

    const config = decorations[theme];
    if (!config) return;

    // Crear nuevas decoraciones
    for (let i = 0; i < config.count; i++) {
      const element = config.create(i);
      container.appendChild(element);
    }
  }

  // Renderizar decoraciones iniciales
  function init() {
    const theme = document.documentElement.getAttribute('data-theme') || 'ocean';
    renderDecorations(theme);
  }

  // Observar cambios en el tema
  const observer = new MutationObserver((mutations) => {
    mutations.forEach((mutation) => {
      if (mutation.attributeName === 'data-theme') {
        const newTheme = document.documentElement.getAttribute('data-theme') || 'ocean';
        renderDecorations(newTheme);
      }
    });
  });

  observer.observe(document.documentElement, {
    attributes: true,
    attributeFilter: ['data-theme']
  });

  // Inicializar cuando el DOM esté listo
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', init);
  } else {
    init();
  }
})();
</script>
