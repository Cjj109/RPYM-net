  </head>
  <body class="water-pattern min-h-screen flex flex-col">
    <ThemeDecorations />
    <Header />
    <main class="flex-1">
      <slot />
    </main>
    <Footer />

    <!-- Theme polling for real-time updates -->
    <script is:inline>
      (function() {
        var POLL_INTERVAL = 30000; // 30 seconds
        var VALID_THEMES = ['ocean', 'carnival', 'christmas', 'easter', 'valentine', 'mundial', 'halloween', 'campeones', 'ramos', 'cuaresma', 'jueves-santo', 'viernes-santo', 'sabado-santo', 'resurreccion', 'luto'];

        // Propiedades inline que paint() del mundial inyecta en <html> — deben
        // limpiarse al salir de mundial para que el CSS del tema entrante tome efecto.
        var MUNDIAL_INLINE_PROPS = [
          '--theme-primary-50','--theme-primary-100','--theme-primary-200','--theme-primary-300',
          '--theme-primary-400','--theme-primary-500','--theme-primary-600','--theme-primary-700',
          '--theme-primary-800','--theme-primary-900','--theme-primary-950',
          '--theme-accent-100','--theme-accent-300','--theme-accent-400','--theme-accent-500','--theme-accent-600',
          '--theme-primary-fg','--btn-from','--btn-to','--btn-text-shadow',
          '--theme-bg-from','--theme-bg-to'
        ];

        function applyTheme(theme) {
          if (!VALID_THEMES.includes(theme)) return;
          // Limpiar inline styles del mundial antes de aplicar cualquier otro tema
          if (theme !== 'mundial') {
            var root = document.documentElement;
            MUNDIAL_INLINE_PROPS.forEach(function(p) { root.style.removeProperty(p); });
          }
          localStorage.setItem('rpym_theme', theme);
          document.documentElement.setAttribute('data-theme', theme);
          // Update meta theme-color for mobile browsers
          var themeColors = {
            ocean: '#0c4a6e',
            carnival: '#7e22ce',
            christmas: '#b91c1c',
            easter: '#be185d',
            valentine: '#e11d48',
            mundial: '#16a34a',
            halloween: '#f97316',
            campeones: '#003DA5',
            ramos: '#4d7c0f',
            cuaresma: '#6b21a8',
            'jueves-santo': '#b45309',
            'viernes-santo': '#374151',
            'sabado-santo': '#4b5563',
            resurreccion: '#a16207',
            luto: '#495057'
          };
          var metaTheme = document.querySelector('meta[name="theme-color"]');
          if (metaTheme) metaTheme.setAttribute('content', themeColors[theme]);
          // Al activar mundial en caliente, sembrar/aplicar el equipo de la sesión
          if (theme === 'mundial' && window.rpymMundial) window.rpymMundial.apply(false);
        }

        async function checkTheme() {
          try {
            var response = await fetch('/api/config/theme', { cache: 'no-store' });
            if (response.ok) {
              var data = await response.json();
              var currentTheme = localStorage.getItem('rpym_theme') || 'ocean';
              // Sincronizar selecciones deshabilitadas antes de (re)aplicar mundial,
              // para que el sorteo ya use el pool actualizado.
              if (window.rpymMundial && data.mundialDisabled) {
                window.rpymMundial.setDisabled(data.mundialDisabled);
              }
              if (data.theme && data.theme !== currentTheme) {
                applyTheme(data.theme);
              }
            }
          } catch (e) {
            console.error('Error checking theme:', e);
          }
        }

        // Initial check after page load
        if (document.readyState === 'complete') {
          checkTheme();
        } else {
          window.addEventListener('load', checkTheme);
        }

        // Poll every 30 seconds
        setInterval(checkTheme, POLL_INTERVAL);

        // Also check when tab becomes visible
        document.addEventListener('visibilitychange', function() {
          if (document.visibilityState === 'visible') {
            checkTheme();
          }
        });
      })();
    </script>

    <!-- Service Worker Registration -->
    <script is:inline>
      if ('serviceWorker' in navigator) {
        window.addEventListener('load', function() {
          navigator.serviceWorker.register('/sw.js')
            .then(function(registration) {
              console.log('SW registrado:', registration.scope);
            })
            .catch(function(error) {
              console.log('SW registro falló:', error);
            });
        });
      }
    </script>
  </body>
</html>
